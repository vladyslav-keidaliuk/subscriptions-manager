# Sample Environment Variables for Subscription Manager
# Copy this file to .env.local and update with your values

# Database Configuration
DATABASE_URL=postgresql://subscriptions_user:dev_password@localhost:5432/subscriptions_dev

# Session Secret (use a strong random string for production)
SESSION_SECRET=your-secret-key-here-make-it-long-and-random

# Node Environment
NODE_ENV=development

# Server Configuration
HOST=0.0.0.0
PORT=3000

# Production PostgreSQL Password (only for production)
# POSTGRES_PASSWORD=your_very_secure_production_password