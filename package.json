{
  "name": "subscription-manager",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "remix build",
    "dev": "remix dev",
    "start": "node server.js",
    "start:remix": "remix-serve build",
    "typecheck": "tsc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:seed:js": "node prisma/seed.cjs",
    "docker:build": "docker build -t subscription-manager .",
    "docker:run": "docker run -p 3000:3000 subscription-manager",
    "docker:dev": "docker-compose up --build",
    "docker:simple": "docker-compose -f docker-compose.simple.yml up --build",
    "docker:minimal": "docker-compose -f docker-compose.minimal.yml up --build",
    "docker:clean": "docker-compose -f docker-compose.clean.yml up --build",
    "docker:working": "docker-compose -f docker-compose.working.yml up --build",
    "docker:restart": "chmod +x docker-restart.sh && ./docker-restart.sh",
    "docker:force-clean": "chmod +x docker-force-clean.sh && ./docker-force-clean.sh",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up --build",
    "docker:down": "docker-compose down",
    "docker:fix": "chmod +x docker-fix.sh && ./docker-fix.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@remix-run/express": "^2.4.1",
    "@remix-run/node": "^2.4.1",
    "@remix-run/react": "^2.4.1",
    "@remix-run/serve": "^2.4.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "isbot": "^3.7.1",
    "morgan": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiny-invariant": "^1.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.4.1",
    "@types/bcryptjs": "^2.4.6", 
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "prisma": "^5.7.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-tsconfig-paths": "^4.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}